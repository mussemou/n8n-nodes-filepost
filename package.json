{
  "name": "n8n-nodes-filepost",
  "version": "0.1.0",
  "description": "n8n community node for FilePost - Upload files and get public URLs instantly",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "file upload",
    "file hosting",
    "public url",
    "cdn"
  ],
  "license": "MIT",
  "homepage": "https://filepost.dev",
  "author": {
    "name": "FilePost",
    "email": "support@filepost.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mussemou/n8n-nodes-filepost.git"
  },
  "main": "index.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FilePostApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/FilePost/FilePost.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && cp -r nodes/FilePost/*.png dist/nodes/FilePost/ 2>/dev/null || true",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "n8n-workflow": "*",
    "typescript": "~5.3.0"
  }
}
